# ─────────────────────────────────────────────────────────────────────────────
# Production environment — VPS (api.singarisaree.com)
# Copy to .env on the server:  cp .env.production.example .env
# Then fill in secrets marked CHANGE_ME
# ─────────────────────────────────────────────────────────────────────────────

NODE_ENV=production
PORT=5001

API_URL=https://api.singarisaree.com
FRONTEND_URL=https://www.singarisaree.com
API_VERSION=v1

# Local PostgreSQL on the same VPS (created by deploy/setup-postgres.sh)
# Format: postgresql://USER:PASSWORD@127.0.0.1:5432/DATABASE
DATABASE_URL=postgresql://singari:CHANGE_ME_DB_PASSWORD@127.0.0.1:5432/singari_sarees

JWT_ACCESS_SECRET=CHANGE_ME_min_32_random_characters
JWT_REFRESH_SECRET=CHANGE_ME_min_32_random_characters
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Razorpay (use live keys in production)
RAZORPAY_KEY_ID=CHANGE_ME
RAZORPAY_KEY_SECRET=CHANGE_ME
RAZORPAY_WEBHOOK_SECRET=CHANGE_ME

SHIPROCKET_EMAIL=CHANGE_ME
SHIPROCKET_PASSWORD=CHANGE_ME
SHIPROCKET_PICKUP_LOCATION=Home
SHIPROCKET_PICKUP_PINCODE=500035
SHIPROCKET_WEBHOOK_TOKEN=CHANGE_ME_random_secret

# Sent.dm — OTP login only
SENT_DM_API_KEY=CHANGE_ME
SENT_DM_OTP_TEMPLATE_ID=CHANGE_ME
SENT_DM_OTP_TEMPLATE_NAME=sent_Verify_Code_2

# Meta WhatsApp Cloud API
WHATSAPP_CLOUD_ACCESS_TOKEN=CHANGE_ME
WHATSAPP_CLOUD_APP_ID=CHANGE_ME
WHATSAPP_CLOUD_PHONE_NUMBER_ID=CHANGE_ME
WHATSAPP_CLOUD_WABA_ID=CHANGE_ME
WHATSAPP_CLOUD_API_VERSION=v25.0
WHATSAPP_CLOUD_WEBHOOK_VERIFY_TOKEN=CHANGE_ME
WHATSAPP_CLOUD_APP_SECRET=CHANGE_ME

# SMTP (Nodemailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=CHANGE_ME
SMTP_PASS=CHANGE_ME
SMTP_FROM_EMAIL=CHANGE_ME
SMTP_FROM_NAME=Singari Sarees
